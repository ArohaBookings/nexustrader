# Copy to config/secrets.env locally. Do not commit the real values.
LIVE_TRADING=false
MT5_LOGIN=replace-with-account-number
MT5_PASSWORD=replace-with-mt5-password
MT5_SERVER=replace-with-broker-server
MT5_TERMINAL_PATH=replace-with-terminal64.exe-path
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_CHAT_ID=replace-after-running-discover-chat
TELEGRAM_WEBHOOK_SECRET=replace-with-long-random-webhook-secret
OPENAI_API_KEY=replace-with-openai-key-for-telegram-ai
NEWS_API_KEY=replace-with-newsapi-key
